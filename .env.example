# Janus — environment contract.
# Copy to .env.local and fill in. Never commit .env.local.
# Every entry below is referenced somewhere in the codebase; if you remove one,
# remove its usage too.

# ───────────────────────── Database (Supabase Postgres) ─────────────────────────
# DATABASE_URL is the pooled connection (PgBouncer port 6543) — runtime queries.
# DIRECT_URL is the direct connection (5432) — required by Prisma migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ───────────────────────── Supabase (Auth + Storage) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never expose. Used for admin operations and webhook handlers.
SUPABASE_SERVICE_ROLE_KEY=""

# ───────────────────────── App ─────────────────────────
# Used to build absolute URLs in transactional emails + Stripe redirects.
APP_URL="http://localhost:3000"

# ───────────────────────── Stripe (Checkout + Identity) ─────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ───────────────────────── Resend (transactional email) ─────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Janus <noreply@example.com>"

# ───────────────────────── Inngest (background jobs) ─────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ───────────────────────── AWS Textract (OCR for docs) ─────────────────────────
# Required at MVP for bank statement + paystub parsing. Leave blank to fall back
# to the stub OCR provider in development.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# ───────────────────────── Screening provider (MVP: SmartMove manual handoff) ─────────────────────────
# MVP uses "smartmove_manual" — applicant pays TransUnion directly off-platform,
# landlord manually enters report fields back into our app. No API key needed.
# v2 will swap this to "tazworks" / "rentprep" / etc. with real credentials.
SCREENING_PROVIDER="smartmove_manual"
# Base URL the applicant is redirected to during the Step 8 handoff. Override
# only if SmartMove publishes a different deep-link URL or we test against a
# sandbox.
SMARTMOVE_INVITE_BASE_URL="https://www.mysmartmove.com"

# ───────────────────────── PII encryption ─────────────────────────
# 32-byte base64-encoded key for AES-256-GCM column encryption.
# Generate: openssl rand -base64 32
# Loss of this key means loss of every encrypted SSN / DOB / bank account.
PII_ENCRYPTION_KEY=""
