# Janus — environment contract.
# Copy to .env.local and fill in. Never commit .env.local.
# Every entry below is referenced somewhere in the codebase; if you remove one,
# remove its usage too.

# ───────────────────────── Database (Supabase Postgres) ─────────────────────────
# DATABASE_URL is the pooled connection (PgBouncer port 6543) — runtime queries.
# DIRECT_URL is the direct connection (5432) — required by Prisma migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ───────────────────────── Supabase (Auth + Storage) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never expose. Used for admin operations and webhook handlers.
SUPABASE_SERVICE_ROLE_KEY=""

# ───────────────────────── App ─────────────────────────
# Used to build absolute URLs in transactional emails + Stripe redirects.
APP_URL="http://localhost:3000"

# ───────────────────────── Stripe (Checkout + Identity) ─────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ───────────────────────── Resend (transactional email) ─────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Janus <noreply@example.com>"

# ───────────────────────── Inngest (background jobs) ─────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ───────────────────────── Plaid (income verification) ─────────────────────────
# Leave blank to use the stub income provider in development.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# ───────────────────────── AWS Textract (OCR for docs) ─────────────────────────
# Leave blank to use the stub OCR provider.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# ───────────────────────── Screening provider (CRA) ─────────────────────────
# "stub" returns realistic fake data so the rest of the app works without API keys.
# Production target: "transunion_smartmove".
SCREENING_PROVIDER="stub"
TRANSUNION_API_KEY=""
TRANSUNION_API_SECRET=""

# ───────────────────────── PII encryption ─────────────────────────
# 32-byte base64-encoded key for AES-256-GCM column encryption.
# Generate: openssl rand -base64 32
# Loss of this key means loss of every encrypted SSN / DOB / bank account.
PII_ENCRYPTION_KEY=""
