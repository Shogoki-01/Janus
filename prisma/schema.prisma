// Janus — multi-tenant rental screening platform.
// Source of truth: ../../../home/dadier/Sync/Averoigne/Projects/Janus/build-spec.md
//
// Tenant root is Organization. Every other tenant-scoped table reaches an
// Organization through the relations defined below; queries must be scoped at
// the application layer (tRPC middleware) and ideally also via Postgres RLS.
//
// MVP architecture note: credit/criminal/eviction reports are NOT pulled
// inside this app. TransUnion SmartMove is a manual handoff — the applicant
// pays TransUnion direct (~$40), the landlord manually re-enters key fields
// (credit_score, hasCriminalFlags severity, hasEvictionFlags bool,
// bankruptcies) and uploads the PDF. The ScreeningProvider interface in
// src/lib/providers/screening.ts is built to v2-swap to a real CRA API.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // pooled (PgBouncer :6543) — used at runtime
  directUrl = env("DIRECT_URL")    // direct (:5432) — used by migrations
}

// ───────────────────────────── enums ─────────────────────────────

enum Role {
  OWNER
  ADMIN
  REVIEWER
}

enum ApplicationStatus {
  DRAFT
  PAID
  // Applicant has paid our platform fee + completed our steps, now waiting on
  // the landlord to invite them through SmartMove and re-ingest the report.
  AWAITING_SCREENING_REPORT
  IN_REVIEW
  DECISIONED
  WITHDRAWN
}

enum StackedDecision {
  APPROVED
  CONDITIONAL_DOUBLE_DEPOSIT
  DENIED
  MANUAL_REVIEW
}

enum ApplicantRole {
  PRIMARY
  CO_APPLICANT
}

enum InviteStatus {
  PENDING
  STARTED
  COMPLETED
}

enum IndividualDecision {
  PASS
  FAIL
  DOUBLE_DEPOSIT_FLAG
}

// Per-applicant state of the SmartMove handoff.
enum ScreeningStatus {
  NOT_STARTED
  INVITED
  REPORT_RECEIVED
  ERROR
}

// Three-state categorization the landlord assigns when reading the SmartMove
// PDF. MAJOR routes the application to MANUAL_REVIEW per HUD individualized
// assessment guidance — we never auto-deny on a criminal flag.
enum CriminalSeverity {
  NONE
  MINOR
  MAJOR
}

enum ReferenceType {
  EMPLOYMENT
  LANDLORD
}

enum ReferenceStatus {
  REQUESTED
  RESPONDED
  NO_RESPONSE
}

enum DocumentType {
  BANK_STATEMENT
  PAYSTUB
  ID
  SECTION8_VOUCHER
  SMARTMOVE_REPORT
  OTHER
}

// ────────────────────────── tenant root ──────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  properties        Property[]
  applicationConfig ApplicationConfig?
}

model User {
  id             String       @id @default(cuid())
  // Maps to Supabase auth.users.id. We keep our own User row so we can
  // attach org/role + audit trails without touching the auth schema.
  authId         String       @unique
  email          String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role
  createdAt      DateTime     @default(now())

  ingestedReports ScreeningReport[] @relation("IngestedBy")

  @@index([organizationId])
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Public slug used in /apply/{slug} URLs.
  slug           String       @unique
  // Address
  addressLine1   String
  addressLine2   String?
  city           String
  state          String
  postalCode     String
  // Jurisdiction string for cap lookups, e.g. "US-CA", "US-NY", "US-CA-SF".
  jurisdiction   String
  // Terms (cents)
  rentCents      Int
  depositCents   Int
  bedrooms       Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  applications Application[]

  @@index([organizationId])
}

model ApplicationConfig {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Decision-engine thresholds.
  minCreditScore    Int          @default(600)
  incomeMultiplier  Float        @default(3.0)
  // Cap pulled from jurisdiction lookup at write time. < 2 disables auto double-deposit.
  maxDepositMonths  Int          @default(2)
  // Per-bedroom occupancy ceiling (informational at MVP; not yet wired into engine).
  occupancyCap      Int          @default(2)
  // Our platform fee, charged via Stripe Checkout. $30 default. Applicant pays
  // TransUnion separately (~$40) for the actual screening report.
  platformFeeCents  Int          @default(3000)
  // FCRA dispute window minimum is 2 years.
  dataRetentionDays Int          @default(730)
  updatedAt         DateTime     @updatedAt
}

// ──────────────────────────── application ────────────────────────────

model Application {
  id                      String            @id @default(cuid())
  propertyId              String
  property                Property          @relation(fields: [propertyId], references: [id])
  status                  ApplicationStatus @default(DRAFT)
  primaryApplicantId      String?           @unique
  primaryApplicant        Applicant?        @relation("PrimaryApplicant", fields: [primaryApplicantId], references: [id])
  // Stacked income (cents) — sum across all completed applicants.
  totalMonthlyIncomeCents Int?
  stackedDecision         StackedDecision?
  decisionReason          String?
  decisionedAt            DateTime?
  isSection8              Boolean           @default(false)
  // { phaName, voucherCents, tenantPortionCents, caseworkerName, caseworkerEmail, caseworkerPhone }
  voucherInfo             Json?
  // Application-level platform-fee payment is unused at MVP (each applicant
  // pays their own — see Applicant.platformFeePaidAt). Kept for future
  // "billed-to-landlord" mode.
  platformFeePaidAt       DateTime?
  stripeSessionId         String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  applicants Applicant[] @relation("ApplicationApplicants")
  auditLogs  AuditLog[]

  @@index([propertyId])
  @@index([status])
}

model Applicant {
  id            String        @id @default(cuid())
  applicationId String
  application   Application   @relation("ApplicationApplicants", fields: [applicationId], references: [id], onDelete: Cascade)
  // The other side of Application.primaryApplicant. Exactly one Applicant per
  // Application can fill this slot (enforced by Application.primaryApplicantId @unique).
  primaryOf     Application?  @relation("PrimaryApplicant")
  role          ApplicantRole
  email         String
  phone         String?
  // PII — encrypted at the app layer via lib/crypto.ts (AES-256-GCM with PII_ENCRYPTION_KEY).
  // Never log. Never return in API responses except masked.
  ssnEncrypted   String?
  dob            DateTime?
  currentAddress String?
  // Co-applicant invite — primary applicant emails this token; co-applicant
  // lands at /apply/co/{inviteToken} to start their own mini-flow.
  inviteToken    String?       @unique
  inviteStatus   InviteStatus  @default(PENDING)
  // ── SmartMove handoff state ──
  // Per-applicant state of the manual SmartMove flow. Updated by the
  // SmartMoveManualProvider as the landlord moves the applicant through the
  // invite → report-received lifecycle.
  screeningStatus            ScreeningStatus @default(NOT_STARTED)
  smartmoveInviteSentAt      DateTime?
  smartmoveReportReceivedAt  DateTime?
  // ── Screening results (populated by landlord-manual ingest at MVP) ──
  // Categorized by the landlord reading the SmartMove PDF. Drives the decision
  // engine's hard-fail check (MAJOR → MANUAL_REVIEW). Null = not yet ingested.
  hasCriminalFlags           CriminalSeverity?
  // Boolean (Yes/No on the SmartMove PDF). Any true value routes to MANUAL_REVIEW.
  hasEvictionFlags           Boolean?
  creditScore                Int?
  bankruptcies               Int?
  // Verified income (cents/month) — Plaid result or doc-OCR result, whichever is higher.
  verifiedMonthlyIncomeCents Int?
  individualDecision         IndividualDecision?
  // Each applicant pays their own platform fee + their own TransUnion fee.
  platformFeePaidAt          DateTime?
  stripeSessionId            String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  references       Reference[]
  documents        Document[]
  screeningReports ScreeningReport[]

  @@index([applicationId])
}

model Reference {
  id                String          @id @default(cuid())
  applicantId       String
  applicant         Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  type              ReferenceType
  contactName       String
  contactEmail      String
  contactPhone      String?
  // Tokenized public URL. No login required — rate-limited per token.
  verificationToken String          @unique
  status            ReferenceStatus @default(REQUESTED)
  responseData      Json?
  requestedAt       DateTime        @default(now())
  respondedAt       DateTime?

  @@index([applicantId])
}

model Document {
  id          String       @id @default(cuid())
  applicantId String
  applicant   Applicant    @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  type        DocumentType
  // Path inside the Supabase Storage bucket; never exposed directly — served via signed URL.
  storagePath String
  // Textract / OCR provider output. Shape depends on document type.
  ocrResult   Json?
  uploadedAt  DateTime     @default(now())

  // When this Document is the uploaded SmartMove PDF, this back-relation links
  // to the ScreeningReport that ingested it.
  screeningReport ScreeningReport? @relation("ScreeningReportPdf")

  @@index([applicantId])
}

model ScreeningReport {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  // "smartmove_manual" at MVP. Future values: "tazworks", "rentprep", etc.
  provider    String
  // Matches the NormalizedScreeningReport interface in src/lib/providers/screening.ts:
  // { credit_score, resident_score, has_criminal_records, criminal_flags[],
  //   has_eviction_records, eviction_flags[], bankruptcies, raw_pdf_url,
  //   provider, fetched_at }
  normalizedData Json
  // Optional link to the uploaded PDF Document (DocumentType.SMARTMOVE_REPORT).
  rawPdfDocumentId String?   @unique
  rawPdfDocument   Document? @relation("ScreeningReportPdf", fields: [rawPdfDocumentId], references: [id])
  // Which landlord/admin entered the report data.
  ingestedByUserId String?
  ingestedByUser   User?     @relation("IngestedBy", fields: [ingestedByUserId], references: [id])
  ingestedAt       DateTime  @default(now())

  @@index([applicantId])
}

model AuditLog {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  // "user" | "system" | "applicant" | "reference"
  actorType     String
  actorId       String?
  // e.g. "status_changed", "report_ingested", "decision_overridden", "consent_signed"
  event         String
  before        Json?
  after         Json?
  createdAt     DateTime    @default(now())

  @@index([applicationId])
  @@index([createdAt])
}
